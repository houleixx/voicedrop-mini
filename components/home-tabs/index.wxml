<view class="home-head" style="padding-top: {{statusBarHeight}}px;">
  <view class="brand-row">
    <view class="brand-wave" aria-hidden="true">
      <view class="wave-line wave-line-short"></view>
      <view class="wave-line wave-line-tall"></view>
      <view class="wave-line wave-line-mid wave-line-last"></view>
    </view>
    <text class="brand-name">VoiceDrop口述</text>
    <view class="settings-button" style="top: {{settingsTop}}px;" bindtap="openSettings" aria-label="设置">
      <text class="settings-icon settings-icon-gear"></text>
    </view>
  </view>
</view>

<scroll-view class="section-tabs" scroll-x enhanced show-scrollbar="{{false}}">
  <view class="section-tabs-inner">
    <view
      class="section-tab {{current === item.key ? 'active' : 'muted-tab'}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-tab="{{item.key}}"
      bindtap="selectTab"
    >
      <text class="section-tab-text">{{item.label}}</text>
      <view wx:if="{{current === item.key}}" class="section-tab-line"></view>
    </view>
  </view>
</scroll-view>
