@import '../../styles/remixicon.wxss';

.config-menu{position:fixed;inset:0;z-index:1000}
.config-menu-scrim{position:absolute;inset:0;background:rgba(42,37,33,.18)}
.config-menu-anchor{position:absolute;box-sizing:border-box;z-index:1;background:#faf6ef;border-radius:10px;box-shadow:0 24px 60px rgba(42,37,33,.4);overflow:hidden}
.config-menu-anchor image{display:block;width:100%}
.config-menu-anchor.text{padding:12px 14px;font-size:16px;line-height:1.7}
.config-menu-card{position:absolute;z-index:2;display:flex;flex-direction:column;box-sizing:border-box;background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 0 16px rgba(42,37,33,.22)}
.config-menu-scroll{display:block;flex:none;width:100%;min-height:0;background:#fff}
.config-menu-row,.config-menu-back{position:relative;display:flex;align-items:center;justify-content:space-between;box-sizing:border-box;height:48px;min-height:48px;padding:0 18px;background:#fff;font-size:16px;color:#2a2521;white-space:nowrap}
.config-menu-row::after,.config-menu-back::after{content:'';position:absolute;right:18px;bottom:0;left:18px;height:1px;background:#ece3d5}
.config-menu-row:last-child::after,.config-menu-back:last-child::after{display:none}
.config-menu-submenu{padding-right:14px;font-weight:600}
.config-menu-chevron{flex:none;width:20px;margin-left:12px;color:#b8ae9e;font-size:28px;font-weight:300;line-height:1;text-align:right}
.config-menu-back{gap:8px;justify-content:flex-start;color:#8a8175;font-size:15px;font-weight:600}
.config-menu-back-icon{flex:none;width:20px;color:#8a8175;font-size:28px;font-weight:300;line-height:1;text-align:left}
.config-menu-section-divider{height:1px;min-height:1px;margin:0 18px;background:#ece3d5}
