.config-menu{position:fixed;inset:0;z-index:1000}.config-menu-scrim{position:absolute;inset:0;background:rgba(42,37,33,.18)}.config-menu-anchor{position:absolute;box-sizing:border-box;z-index:1;background:#faf6ef;border-radius:10px;box-shadow:0 24px 60px rgba(42,37,33,.4);overflow:hidden}.config-menu-anchor image{display:block;width:100%}.config-menu-anchor.text{padding:12px 14px;font-size:16px;line-height:1.7}.config-menu-card{position:absolute;z-index:2;width:240px;background:#faf6ef;border-radius:13px;overflow-x:hidden;overflow-y:auto;-webkit-overflow-scrolling:touch;box-shadow:0 18px 44px rgba(42,37,33,.32)}.config-menu-row,.config-menu-back{display:flex;align-items:center;justify-content:space-between;box-sizing:border-box;min-height:48px;padding:0 16px;border-bottom:1px solid #efe7d9;font-size:15px;color:#2a2521}.config-menu-preview{max-width:140px;color:#a79f93;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.config-menu-back{gap:9px;justify-content:flex-start;min-height:42px;background:#f1ebe0;color:#6b6357;font-size:13px;font-weight:600}.config-menu-group-separator{height:7px;background:#f1ebe0}
