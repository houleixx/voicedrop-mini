@import '../../styles/remixicon.wxss';
.screen{min-height:100vh;background:#faf6ef;color:#2a2521}.prompt-new-page{padding:0 0 80rpx;padding-top:180rpx}.field-label{display:block;margin-bottom:14rpx;color:#756d63;font-size:28rpx;font-weight:600}.section-gap{margin-top:32rpx}.field{box-sizing:border-box;width:100%;height:96rpx;padding:0 26rpx;border:1rpx solid #e5ded2;border-radius:22rpx;background:#fff;font-size:32rpx}.prompt-field{height:374rpx;padding:24rpx;line-height:1.55}.applies-head{display:flex;align-items:center;justify-content:space-between;margin-top:28rpx;color:#aaa093;font-size:23rpx}.applies-head .field-label{margin:0}.apply-options{display:flex;gap:18rpx;margin-top:14rpx}.apply-option{display:flex;height:166rpx;flex:1;align-items:center;justify-content:center;flex-direction:column;gap:8rpx;border:2rpx solid #e5ded2;border-radius:22rpx;background:#fff;color:#8a8175;font-size:28rpx}.apply-option>text:first-child{font-size:40rpx}.apply-option.selected{border-color:#c7432f;color:#c7432f;box-shadow:inset 0 0 0 1rpx #c7432f}.apply-check{height:26rpx;font-size:28rpx;font-weight:800}.bottom-save{width:320rpx;height:88rpx!important;line-height:88rpx!important;margin:42rpx auto 0!important;border-radius:18rpx!important;background:#c7432f!important;color:#fff!important;font-size:30rpx!important;font-weight:700}.bottom-save.disabled,.bottom-save[disabled]{background:#c3baaa!important;color:#fff!important;opacity:.72}.error{display:block;margin-bottom:18rpx;color:#c7432f}.screen{padding:0 32rpx}
