@import '../../styles/remixicon.wxss';

.recording-screen {
  position: relative;
  height: 100vh;
  background: #faf6ef;
}

.recording-screen home-tabs {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: #faf6ef;
}

.scroll-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
}

.scroll-inner {
  padding: 0 32rpx 48rpx;
}

.scroll-inner.with-record-dock {
  padding-bottom: 230rpx;
}

.community-feed-tabs {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 9;
  display: flex;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 32rpx;
  align-items: center;
  background: #f3efe7;
}

.community-feed-tab {
  margin-right: 36rpx;
  color: #8a8175;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1;
  transform: translateY(4rpx);
}

.community-feed-tab.active {
  color: #27231f;
  font-weight: 800;
}

.notice,
.empty {
  margin-top: 38rpx;
  padding: 42rpx;
  color: #8d8578;
  font-size: 28rpx;
  text-align: center;
  justify-content: center;
}

.loading-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #efe8dd;
  border-top-color: #c7432f;
  border-radius: 50%;
  animation: loading-spin 0.8s linear infinite;
}

.pull-refresh-indicator {
  display: flex;
  width: 100%;
  height: 60px;
  align-items: center;
  justify-content: center;
}

.pull-refresh-spinner {
  box-sizing: border-box;
  width: 30px;
  height: 30px;
  flex: 0 0 30px;
  position: relative;
  top: 8px;
}

@keyframes loading-spin {
  to {
    transform: rotate(360deg);
  }
}

.empty {
  display: flex;
  min-height: 360rpx;
  margin-top: 76rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border: 0;
  border-radius: 0;
  background: transparent;
  text-align: center;
}

.empty-title {
  display: block;
  color: #2a2521;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  color: #a7a095;
  font-size: 26rpx;
  line-height: 1.45;
}

.tag-tabs {
  width: 100%;
  margin-top: 28rpx;
  white-space: nowrap;
}

.tag-tab {
  display: inline-flex;
  width: auto;
  min-width: 108rpx;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 24rpx;
  border: 1rpx solid #eee5da;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  color: #8d8578;
  background: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 56rpx;
}

.tag-tab.active {
  border-color: #e9332c;
  color: #e9332c;
  background: #fff1ef;
  font-weight: 800;
}

.list {
  margin-top: 34rpx;
}

/* Swipe-to-delete row container */
.record-row {
  position: relative;
  margin-bottom: 24rpx;
}

.record-card {
  position: relative;
  z-index: 1;
  transition: transform 0.2s ease-out;
  display: flex;
  min-height: 148rpx;
  padding: 30rpx 28rpx 30rpx 32rpx;
  overflow: hidden;
  border-radius: 34rpx;
  align-items: center;
  background: #ffffff;
  touch-action: pan-y;
}

/* Delete button revealed by swipe */
.delete-btn {
  position: absolute;
  right: 2rpx;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e9332c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 0 34rpx 34rpx 0;
  z-index: 0;
}

.record-icon-wrapper {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  margin-right: 30rpx;
  flex: 0 0 auto;
}

.record-icon {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: #fbeae7;
}

.record-cover {
  display: block;
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
}

/* Command reference badge (Android: commandNumberBadge) */
.command-badge {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #d8d8d8;
  color: #2a2521;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.record-wave {
  display: flex;
  width: 44rpx;
  height: 44rpx;
  align-items: center;
  justify-content: center;
}

.record-wave-line {
  display: block;
  width: 6rpx;
  margin-right: 8rpx;
  border-radius: 999rpx;
  background: #e9332c;
}

.record-wave-line-last {
  margin-right: 0;
}

.record-wave-line-short {
  height: 22rpx;
}

.record-wave-line-mid {
  height: 28rpx;
}

.record-wave-line-tall {
  height: 38rpx;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-name {
  display: block;
  overflow: hidden;
  color: #27231f;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  display: flex;
  min-width: 0;
  margin-top: 18rpx;
  align-items: center;
  color: #a9a297;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.2;
  white-space: nowrap;
}

.record-meta text:first-child {
  overflow: hidden;
  min-width: 0;
  text-overflow: ellipsis;
}

.duration {
  margin-left: 24rpx;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  margin: 0 14rpx 0 22rpx;
  border-radius: 50%;
  background: #4e886c;
}

.status {
  overflow: hidden;
  max-width: 142rpx;
  color: #5f9278;
  text-overflow: ellipsis;
}

.chevron {
  margin-left: 20rpx;
  flex: 0 0 30rpx;
  width: 30rpx;
  color: #cec8bd;
  font-size: 58rpx;
  font-weight: 300;
  line-height: 1;
  text-align: right;
}

/* Silent (no voice) recording -- muted colors like Android */
.record-card.silent .record-icon {
  background: #f4f0eb;
}

.record-card.silent .record-wave-line {
  background: #d1c8bd;
}

.record-card.silent .record-name {
  color: #6f6a63;
}

.record-card.silent .record-meta {
  color: #b9b2a8;
}

.record-card.silent .status-dot {
  background: #b9b2a8;
}

.record-card.silent .status {
  color: #b9b2a8;
}

.record-card.silent .chevron {
  color: #d8d0c5;
}

.record-dock {
  position: fixed;
  right: 0;
  bottom: 42rpx;
  left: 0;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}

.mic-button {
  display: flex;
  width: 128rpx;
  height: 128rpx;
  min-width: 128rpx;
  max-width: 128rpx;
  min-height: 128rpx;
  max-height: 128rpx;
  padding: 0;
  flex: 0 0 128rpx;
  align-items: center;
  justify-content: center;
  border: 10rpx solid #ffffff;
  border-radius: 9999rpx;
  background: #ef332d;
  box-shadow: 0 10rpx 32rpx rgba(54, 46, 38, 0.18);
  line-height: 1;
  overflow: hidden;
  pointer-events: auto;
}

.mic-button.recording {
  background: #2a2521;
}

.mic-icon {
  position: relative;
  width: 34rpx;
  height: 46rpx;
}

.mic-head {
  position: absolute;
  top: 0;
  left: 9rpx;
  width: 16rpx;
  height: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.mic-head::after {
  position: absolute;
  right: -8rpx;
  bottom: -7rpx;
  left: -8rpx;
  height: 17rpx;
  border-right: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  border-left: 4rpx solid #ffffff;
  border-radius: 0 0 17rpx 17rpx;
  content: "";
}

.mic-stand {
  position: absolute;
  top: 33rpx;
  left: 15rpx;
  width: 5rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.mic-base {
  position: absolute;
  right: 6rpx;
  bottom: 0;
  left: 6rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.dock-hint {
  margin-top: 18rpx;
  color: #8d8578;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1;
  text-shadow: 0 2rpx 6rpx rgba(250, 246, 239, 0.9), 0 0 2rpx #faf6ef;
  transition: color 0.2s;
}

.dock-hint.talking {
  color: #e9332c;
}

.dock-hint.canceled {
  color: #e9332c;
}

/* Mic button wrapper for talk mode */
.mic-button-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.mic-button-wrapper.talking .mic-button {
  background: #2a2521;
}

.mic-button-wrapper.canceled .mic-button {
  background: #2a2521;
  opacity: 0.5;
}

/* iOS VoiceFeedbackStack: distinct listening, in-flight, reply and error cards. */
.fab-status {
  position: relative;
  display: flex;
  max-width: calc(100vw - 64rpx);
  box-sizing: border-box;
  padding: 18rpx 28rpx;
  margin: 0 32rpx 16rpx;
  align-items: center;
  border: 2rpx solid #e8decf;
  border-radius: 26rpx;
  background: #ffffff;
  color: #2a2521;
  box-shadow: 0 8rpx 24rpx rgba(54, 46, 38, 0.10);
  font-size: 28rpx;
  font-weight: 500;
  text-align: left;
  line-height: 1.4;
  min-height: 24rpx;
}

.fab-status::before {
  display: inline-flex;
  width: 30rpx;
  margin-right: 14rpx;
  flex: 0 0 30rpx;
  align-items: center;
  justify-content: center;
  color: #d8593b;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.fab-status.transcript {
  border-color: #2e2823;
  background: #2e2823;
  color: #fbf6ee;
}

.fab-status.transcript::before {
  display: none;
}

.fab-status.transcript::after {
  position: absolute;
  bottom: -14rpx;
  left: 50%;
  width: 0;
  height: 0;
  border-top: 16rpx solid #2e2823;
  border-right: 18rpx solid transparent;
  border-left: 18rpx solid transparent;
  content: "";
  transform: translateX(-50%);
}

.fab-status.queue {
  border-color: rgba(216, 89, 59, 0.5);
  background: #f6e4dc;
  color: #2a2521;
}

.fab-status.queue::before {
  content: "✎";
}

.fab-status.reply {
  border-color: #e8decf;
  background: #ffffff;
  color: #2a2521;
}

.fab-status.reply::before {
  content: "✦";
}

.fab-status.error {
  border-color: rgba(192, 57, 43, 0.7);
  background: #ffffff;
  color: #2a2521;
}

.fab-status.error::before {
  color: #c0392b;
  content: "!";
}

.post-list {
  margin-top: 34rpx;
}

.post {
  display: flex;
  min-height: 148rpx;
  margin-bottom: 24rpx;
  padding: 30rpx 28rpx 30rpx 32rpx;
  border-radius: 34rpx;
  align-items: flex-start;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(65, 52, 41, 0.03);
}

.post-icon {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  margin-right: 30rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: #f6e4dc;
}

.doc-icon-img {
  width: 48rpx;
  height: 48rpx;
  color: #d8593b;
  font-size: 48rpx;
  line-height: 48rpx;
  text-align: center;
}

.post-main {
  top: 35rpx;
  width: 20rpx;
}

.post-main {
  flex: 1;
  min-width: 0;
}

.post-title {
  display: block;
  overflow: hidden;
  color: #27231f;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  display: flex;
  min-width: 0;
  margin-top: 18rpx;
  align-items: center;
  color: #a9a297;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.2;
  white-space: nowrap;
}

.post-meta text:first-child {
  overflow: hidden;
  min-width: 0;
  text-overflow: ellipsis;
}

.post-time {
  margin-left: 24rpx;
}

.community-post-list {
  display: flex;
  margin-top: 16rpx;
  align-items: flex-start;
  gap: 16rpx;
}

.community-post-column {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.community-card {
  display: flex;
  box-sizing: border-box;
  width: 100%;
  margin-bottom: 18rpx;
  overflow: hidden;
  border-radius: 24rpx;
  flex-direction: column;
  vertical-align: top;
  break-inside: avoid;
  background: #ffffff;
}

.community-card.has-photo {
  background: #ffffff;
}

.community-palette-0 {
  background: linear-gradient(135deg, #fbefe0, #f6e3ce);
}

.community-palette-1 {
  background: linear-gradient(135deg, #ede7dc, #e2dacb);
}

.community-palette-2 {
  background: linear-gradient(135deg, #e7ede3, #d6e0ce);
}

.community-card-image {
  display: block;
  width: 100%;
  min-height: 180rpx;
  background: #eee8de;
}

.community-card-body {
  display: flex;
  box-sizing: border-box;
  width: 100%;
  padding: 22rpx 24rpx 24rpx;
  flex-direction: column;
}

.community-reply-badge {
  display: inline-flex;
  align-self: flex-start;
  margin-bottom: 14rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  align-items: center;
  color: #d8593b;
  background: #fbe3dc;
  font-size: 22rpx;
  line-height: 1.3;
}

.community-reply-badge-icon {
  width: 22rpx;
  height: 22rpx;
  margin-right: 8rpx;
  flex: 0 0 auto;
}

.community-card-title {
  display: -webkit-box;
  overflow: hidden;
  color: #27231f;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.32;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.community-card.has-photo .community-card-title {
  -webkit-line-clamp: 2;
}

.community-card-preview {
  display: -webkit-box;
  margin-top: 16rpx;
  overflow: hidden;
  color: #8a7b63;
  font-size: 25rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.community-card-meta {
  display: flex;
  min-width: 0;
  margin-top: 20rpx;
  align-items: center;
}

.community-avatar {
  display: flex;
  width: 40rpx;
  height: 40rpx;
  flex: 0 0 40rpx;
  border-radius: 50%;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-align: center;
}

.community-author {
  min-width: 0;
  margin-left: 12rpx;
  overflow: hidden;
  flex: 1;
  color: #8a8175;
  font-size: 24rpx;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.community-count {
  display: inline-flex;
  margin-left: 12rpx;
  flex: 0 0 auto;
  align-items: center;
  color: #8a8175;
  font-size: 24rpx;
  line-height: 1;
}

.community-like-count {
  color: #d8593b;
}

.community-like-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
  color: #d8593b;
  font-size: 24rpx;
  line-height: 24rpx;
}

.community-reply-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
  flex: 0 0 auto;
  color: #8a8175;
  font-size: 24rpx;
  line-height: 24rpx;
}
