<template name="community-card">
  <view class="community-card {{item.coverPhotoUrl ? 'has-photo' : item.paletteClass}}"
        data-share-id="{{item.shareId}}" bindtap="openPost" bindlongpress="confirmCommunityUnshare">
    <image wx:if="{{item.coverPhotoUrl}}" class="community-card-image"
           src="{{item.coverPhotoUrl}}" mode="widthFix" lazy-load
           data-cover-key="{{item.coverPhotoKey}}" bindload="onCommunityCoverLoad" />
    <view class="community-card-body">
      <view wx:if="{{item.isPrompt}}" class="community-prompt-badge">提示词</view>
      <view wx:if="{{item.isReply}}" class="community-reply-badge">
        <view class="community-reply-badge-icon community-reply-icon-accent"></view>
        <text>回应</text>
      </view>
      <text class="community-card-title">{{item.title || '(无题)'}}</text>
      <text wx:if="{{item.preview && !item.coverPhotoUrl}}" class="community-card-preview">{{item.preview}}</text>
      <view class="community-card-meta">
        <text class="community-avatar" style="background: {{item.avatarColor}};">{{item.authorInitial}}</text>
        <text class="community-author">{{item.authorDisplay}}</text>
        <view class="community-count community-like-count">
          <text class="community-like-icon ri-heart-fill"></text>
          <text>{{item.likeCount}}</text>
        </view>
        <view wx:if="{{item.replyCount > 0}}" class="community-count community-reply-count">
          <text class="community-reply-icon ri-chat-2-line"></text>
          <text>{{item.replyCount}}</text>
        </view>
      </view>
    </view>
  </view>
</template>

<view class="screen recording-screen">
  <home-tabs current="{{currentHomeTab}}" tabs="{{homeTabs}}" bind:change="switchHomeTab" bind:settings="openSettings" />

  <view wx:if="{{activeTab === 'community'}}" class="community-feed-tabs" style="top: {{scrollContentTop}}px;">
    <view class="community-feed-tab {{communityFeedTab === 'recommended' ? 'active' : ''}}"
          data-feed-tab="recommended" bindtap="selectCommunityFeed">推荐</view>
    <view class="community-feed-tab {{communityFeedTab === 'latest' ? 'active' : ''}}"
          data-feed-tab="latest" bindtap="selectCommunityFeed">最新</view>
    <view class="community-feed-tab {{communityFeedTab === 'replies' ? 'active' : ''}}"
          data-feed-tab="replies" bindtap="selectCommunityFeed">回应</view>
    <view class="community-feed-tab {{communityFeedTab === 'prompts' ? 'active' : ''}}"
          data-feed-tab="prompts" bindtap="selectCommunityFeed">提示词</view>
  </view>

  <scroll-view
    class="scroll-content"
    scroll-y
    enhanced
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    refresher-default-style="none"
    refresher-threshold="60"
    refresher-background="#faf6ef"
    bindrefresherrefresh="onRefresherRefresh"
    style="top: {{activeTab === 'community' ? communityScrollContentTop : scrollContentTop}}px;"
    bindtouchstart="onScreenTouchStart"
  >
    <view slot="refresher" class="pull-refresh-indicator">
      <view class="loading-spinner pull-refresh-spinner" aria-hidden="true"></view>
    </view>
    <view class="scroll-inner {{activeTab === 'recordings' ? 'with-record-dock' : ''}}">
    <block wx:if="{{activeTab === 'recordings'}}">
      <view wx:if="{{error}}" class="notice">{{error}}</view>
      <view wx:elif="{{loading}}" class="notice loading-notice">
        <view class="loading-spinner" aria-hidden="true"></view>
        <text>正在加载...</text>
      </view>

      <view wx:if="{{!loading && !error && records.length === 0}}" class="empty card">
        <text class="empty-title">还没有录音</text>
        <text class="empty-sub">{{selectedTag ? '当前标签还没有录音。' : '录一段话，VoiceDrop 会把它整理成文章。'}}</text>
      </view>

      <view class="list" wx:if="{{!loading && !error && records.length > 0}}">
        <view class="record-row" wx:for="{{records}}" wx:key="stem"
              bindtouchstart="onRowTouchStart"
              bindtouchmove="onRowTouchMove"
              bindtouchend="onRowTouchEnd"
              data-index="{{index}}">
          <view class="record-card {{item.isEmpty ? 'silent' : ''}}" style="transform: translateX({{item._translateX || 0}}px);" data-index="{{index}}" bindtap="openDetail">
            <view class="record-icon-wrapper">
              <image wx:if="{{item.coverPhotoUrl}}" class="record-cover"
                     src="{{item.coverPhotoUrl}}" mode="aspectFill" lazy-load
                     data-stem="{{item.stem}}" binderror="onRecordCoverError" />
              <view wx:else class="record-icon" aria-hidden="true">
                <view class="record-wave">
                  <view class="record-wave-line record-wave-line-short"></view>
                  <view class="record-wave-line record-wave-line-tall"></view>
                  <view class="record-wave-line record-wave-line-mid record-wave-line-last"></view>
                </view>
              </view>
              <view wx:if="{{commandTalking && item._commandRef}}" class="command-badge">
                {{item._commandRef}}
              </view>
            </view>
            <view class="record-main">
              <text class="record-name">{{item.rowTitle}}</text>
              <view class="record-meta">
                <text>{{item.timeLabel || item.uploaded || '上传中'}}</text>
                <text class="duration">{{item.durationLabel || '音频'}}</text>
                <text class="status-dot"></text>
                <text class="status">{{item.statusLabel}}</text>
              </view>
            </view>
            <text class="chevron" aria-hidden="true">›</text>
          </view>
          <view class="delete-btn" data-index="{{index}}" bindtap="confirmDelete">删除</view>
        </view>
      </view>
    </block>

    <block wx:elif="{{activeTab === 'community'}}">
      <view wx:if="{{communityError}}" class="notice">{{communityError}}</view>
      <view wx:elif="{{communityLoading}}" class="notice loading-notice">
        <view class="loading-spinner" aria-hidden="true"></view>
        <text>正在加载...</text>
      </view>
      <view wx:elif="{{communityPosts.length === 0}}" class="empty card">
        <text class="empty-title">{{communityFeedTab === 'prompts' ? '社区暂无提示词' : '社区暂无文章'}}</text>
        <text class="empty-sub">{{communityFeedTab === 'prompts' ? '稍后刷新，或先分享自己的提示词。' : '稍后刷新，或先分享自己的文章。'}}</text>
      </view>

      <view wx:else class="community-post-list">
        <view class="community-post-column">
          <block wx:for="{{communityLeftPosts}}" wx:key="shareId">
            <template is="community-card" data="{{item: item}}" />
          </block>
        </view>
        <view class="community-post-column">
          <block wx:for="{{communityRightPosts}}" wx:key="shareId">
            <template is="community-card" data="{{item: item}}" />
          </block>
        </view>
      </view>
    </block>
    </view>
  </scroll-view>

  <view wx:if="{{activeTab === 'recordings'}}" class="record-dock">
    <!-- iOS VoiceFeedbackStack colors: transcript / queue / reply / error -->
    <view wx:if="{{commandStatusText}}" class="fab-status {{commandStatusKind}}">
      {{commandStatusText}}
    </view>

    <view class="mic-button-wrapper {{commandTalking ? 'talking' : ''}} {{commandCanceled ? 'canceled' : ''}}">
      <view class="mic-button {{recording ? 'recording' : ''}}"
            bindtouchstart="onMicTouchStart"
            bindtouchmove="onMicTouchMove"
            bindtouchend="onMicTouchEnd"
            bindtouchcancel="onMicTouchCancel"
            aria-label="{{recording ? '停止录音' : '开始录音'}}">
        <view class="mic-icon">
          <view class="mic-head"></view>
          <view class="mic-stand"></view>
          <view class="mic-base"></view>
        </view>
      </view>
    </view>

    <!-- Hint text below button (Android: fabLabel) -->
    <text class="dock-hint {{commandTalking ? 'talking' : ''}} {{commandCanceled ? 'canceled' : ''}}">{{dockHint}}</text>
  </view>
  <audio-consent-dialog
    visible="{{audioConsentVisible}}"
    bind:agree="onAudioConsentAgree"
    bind:decline="onAudioConsentDecline"
    bind:viewagreement="onAudioConsentViewAgreement"
  />
</view>
