/* Prompt and community rows share the same inset-divider rhythm. */
.prompt-card .prompt-row{border-bottom:0}
.prompt-row-content::after{content:'';position:absolute;right:0;bottom:0;left:110rpx;height:1rpx;background:#efe7d9}
.prompt-card .prompt-row.depth-1 .prompt-row-content::after{left:144rpx}
.prompt-card .prompt-row:last-child .prompt-row-content::after{display:none}
.market-row{position:relative;border-bottom:0}
.market-row::after{content:'';position:absolute;right:0;bottom:0;left:110rpx;height:1rpx;background:#efe7d9}
.market-row:last-child::after{display:none}

/* Loading indicators stay above their state labels. */
.prompt-loading-state,.market-loading-state,.market-detail-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14rpx}
.prompt-loading-spinner{box-sizing:border-box;width:34rpx;height:34rpx;flex:none;border:4rpx solid #e2d9cd;border-top-color:#d8593b;border-radius:50%;animation:prompt-loading-spin .8s linear infinite}
@keyframes prompt-loading-spin{to{transform:rotate(360deg)}}

/* Community prompt list mirrors the compact Android reference. */
.market-heading{margin-bottom:18rpx;color:#756d63;font-size:28rpx;font-weight:700}
.market-filter{border:1rpx solid #e5dccb;background:#fff}
.market-filter.active{border-color:#2b2823;background:#2b2823;color:#fff}
.market-card{border:1rpx solid #e5dccb}
.prompt-icon.text-icon{background:#eaf1ec;color:#5e8a6a;}
.market-import{display:flex;flex:none;align-items:center;gap:4rpx}
.market-row-arrow{width:24rpx;color:#b8ae9e;font-size:38rpx;font-weight:300;line-height:1;text-align:right}

/* Community prompt detail is a compact, scrollable bottom sheet with a fixed action. */
.market-detail-sheet{position:relative;display:flex;height:74vh;max-height:calc(100vh - 180rpx);flex-direction:column;padding:0;overflow:hidden;border-radius:32rpx 32rpx 0 0;background:#fffaf4;animation:market-detail-up .22s ease-out}
@keyframes market-detail-up{from{transform:translateY(100%)}to{transform:translateY(0)}}
.market-detail-close{position:absolute;z-index:2;top:24rpx;right:24rpx;display:flex;width:64rpx;height:64rpx;align-items:center;justify-content:center;color:#aaa093;font-size:44rpx}
.market-detail-scroll{width:100%;min-height:0;flex:1}
.market-detail-content{box-sizing:border-box;padding:36rpx 36rpx 30rpx}
.market-detail-kind{display:inline-block;padding:6rpx 12rpx;border-radius:8rpx;background:#eaf1ec;color:#5e8a6a;font-size:23rpx;font-weight:700;text-align:left}
.market-detail-kind.image-kind{background:#f6e4dc;color:#d8593b}
.market-detail-title{display:block;margin-top:30rpx;padding-right:58rpx;color:#2a2521;font-size:42rpx;font-weight:800;line-height:1.32;text-align:left}
.market-detail-author-row{display:flex;align-items:center;gap:14rpx;margin-top:24rpx}
.market-detail-avatar{display:flex;width:46rpx;height:46rpx;align-items:center;justify-content:center;border-radius:50%;background:#e1ad58;color:#fff;font-size:24rpx;font-weight:700}
.market-detail-author{margin:0;color:#8a8175;font-size:25rpx;text-align:left}
.market-detail-stats{overflow:hidden;margin-top:28rpx;border:1rpx solid #e5dccb;border-radius:18rpx;background:#fff}
.market-stat{height:106rpx}
.market-stat+.market-stat{border-left-color:#ece5db}
.market-detail-prompt-heading{display:block;margin-top:30rpx;color:#8a8175;font-size:26rpx;font-weight:700}
.market-detail-prompt{box-sizing:border-box;min-height:260rpx;height:auto;margin-top:14rpx;padding:24rpx;border:1rpx solid #e5dccb;border-radius:18rpx;background:#fff;color:#544c44;font-size:28rpx;line-height:1.72;white-space:pre-wrap}
.market-detail-loading{min-height:212rpx;color:#aaa093;font-size:24rpx}
.market-detail-footer{display:flex;flex:none;align-items:center;justify-content:center;padding:18rpx 36rpx calc(20rpx + env(safe-area-inset-bottom));border-top:1rpx solid #eee6dc;background:#fffaf4}
.market-detail-import{display:flex!important;box-sizing:border-box;width:auto;min-width:0;max-width:100%;height:88rpx!important;flex:1;margin:0!important;padding:0!important;align-items:center;justify-content:center;border-radius:20rpx!important;font-size:30rpx!important;line-height:normal!important;text-align:center}
.market-detail-import::after{border:0}

/* Keep trailing status badges stable while long prompt titles ellipsize. */
.title-line{width:100%}
.title-line .prompt-title{min-width:0;flex:1}
.origin-badge{flex:none;white-space:nowrap;word-break:keep-all;}
.origin-badge.user-origin{background:#e7f1e8;color:#5e8a6a}
.origin-badge.custom-origin{background:#fbead2;color:#c98a2e}

/* Bottom sheets stay mounted until their downward exit animation completes. */
.sheet-mask{animation:sheet-mask-in .22s ease-out both}
.new-sheet,.import-sheet{animation:bottom-sheet-up .22s ease-out both}
.sheet-mask.sheet-closing{pointer-events:none;animation:sheet-mask-out .2s ease-in both}
.sheet-mask.sheet-closing .new-sheet,.sheet-mask.sheet-closing .import-sheet,.sheet-mask.sheet-closing .market-detail-sheet{animation:bottom-sheet-down .2s ease-in both}
@keyframes bottom-sheet-up{from{transform:translateY(100%)}to{transform:translateY(0)}}
@keyframes bottom-sheet-down{from{transform:translateY(0)}to{transform:translateY(100%)}}
@keyframes sheet-mask-in{from{background:rgba(42,37,33,0)}to{background:rgba(42,37,33,.22)}}
@keyframes sheet-mask-out{from{background:rgba(42,37,33,.22)}to{background:rgba(42,37,33,0)}}
