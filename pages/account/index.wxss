@import '../../styles/remixicon.wxss';

.account-screen {
  padding: 0 32rpx;
}

.account-body {
  padding-bottom: 36rpx;
}

.account-card,
.stats-card,
.delete-card {
  border: 1rpx solid #efe4d4;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(85, 67, 48, 0.06);
}

.account-card {
  margin-top: 0;
  padding: 32rpx;
}

.account-intro {
  display: flex;
  align-items: center;
}

.account-badge {
  display: flex;
  width: 82rpx;
  height: 82rpx;
  min-width: 82rpx;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #2a2521;
}

.account-badge-icon {
  display: block;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 42rpx;
  text-align: center;
  vertical-align: 0;
}

.account-intro-copy {
  flex: 1;
  min-width: 0;
  margin-left: 26rpx;
}

.account-intro-title {
  display: block;
  color: #2a2521;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.account-intro-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #8a8175;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.35;
}

.card-divider {
  height: 1rpx;
  margin: 30rpx 0;
  background: #efe8dd;
}

.lower-divider {
  margin-top: 12rpx;
  margin-bottom: 0;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  color: #aaa39a;
  font-size: 25rpx;
  font-weight: 900;
}

.token-label {
  margin-top: 28rpx;
}

.copy-field {
  display: flex;
  min-height: 70rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  border: 1rpx solid #efe4d4;
  border-radius: 8rpx;
  background: #fffaf3;
}

.copy-value {
  flex: 1;
  min-width: 0;
  color: #2a2521;
  font-size: 28rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.token-value {
  color: #8a8175;
  letter-spacing: 1rpx;
}

.copy-action {
  display: flex;
  align-items: center;
  margin-left: 18rpx;
  color: #c7432f;
  font-size: 24rpx;
  font-weight: 900;
}

.copy-action-icon {
  margin-right: 8rpx;
}

.icon-only {
  font-size: 40rpx;
}

.import-row {
  display: flex;
  min-height: 76rpx;
  align-items: center;
  margin-top: 20rpx;
  color: #c7432f;
}

.import-icon {
  width: 46rpx;
  color: #c7432f;
  font-size: 34rpx;
  font-weight: 900;
}

.import-text {
  font-size: 27rpx;
  font-weight: 800;
}

.login-row {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: space-between;
}

.login-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.login-mark {
  margin-right: 16rpx;
  color: #8a8175;
  font-size: 30rpx;
}

.login-text {
  color: #8a8175;
  font-size: 28rpx;
  font-weight: 700;
}

.login-right {
  display: flex;
  align-items: center;
}

.login-action {
  color: #c7432f;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.login-action.disabled {
  opacity: 0.52;
}

.section-label {
  display: block;
  margin: 38rpx 0 14rpx;
  padding-left: 8rpx;
  color: #aaa39a;
  font-size: 25rpx;
  font-weight: 900;
}

.stats-card {
  overflow: hidden;
}

.stat-row {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.stat-row + .stat-row {
  border-top: 1rpx solid #f0e5d7;
}

.stat-title {
  color: #2a2521;
  font-size: 30rpx;
  font-weight: 800;
}

.stat-value {
  color: #8a8175;
  font-size: 28rpx;
  font-weight: 800;
}

.section-note {
  display: block;
  margin: 16rpx 8rpx 0;
  color: #b2aaa1;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.45;
}

.delete-card {
  display: flex;
  min-height: 84rpx;
  align-items: center;
  padding: 0 28rpx;
  color: #d84235;
  font-size: 30rpx;
  font-weight: 800;
}

/* Token import modal dialog */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-card {
  width: 560rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dialog-title {
  color: #2a2521;
  font-size: 36rpx;
  font-weight: 900;
  text-align: center;
  margin-bottom: 16rpx;
}

.dialog-desc {
  color: #8a8175;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.dialog-input-shell {
  display: flex;
  width: 100%;
  height: 88rpx;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 22rpx;
  border: 1rpx solid #eadccd;
  border-radius: 14rpx;
  background: #fffaf3;
  box-sizing: border-box;
}

.dialog-input {
  flex: 1;
  width: 100%;
  height: 100%;
  min-width: 0;
  padding: 0;
  background: transparent;
  color: #2a2521;
  font-size: 26rpx;
  box-sizing: border-box;
}

.dialog-actions {
  display: flex;
  flex-direction: row;
  width: 100%;
  margin-top: 0;
  position: relative;
}

.dialog-divider {
  height: 1rpx;
  background: #efe8dd;
  width: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.dialog-btn {
  flex: 1;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-btn-cancel text {
  color: #c7432f;
  font-size: 30rpx;
  font-weight: 800;
}

.dialog-btn-confirm text {
  color: #c7432f;
  font-size: 30rpx;
  font-weight: 900;
}

.dialog-btn-separator {
  width: 1rpx;
  background: #efe8dd;
}
