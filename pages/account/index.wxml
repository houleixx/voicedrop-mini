<view class="screen settings-screen account-screen">
  <page-header title="账户" />
  <view class="page-body account-body">
    <view class="account-card">
      <view class="account-intro">
        <view class="account-badge">
          <text class="account-badge-icon">✓</text>
        </view>
        <view class="account-intro-copy">
          <text class="account-intro-title">账户</text>
          <text class="account-intro-subtitle">在这台设备上自动生成，不需要用户名或密码。</text>
        </view>
      </view>

      <view class="card-divider"></view>

      <text class="field-label">你的 ID</text>
      <view class="copy-field" bindtap="copyId">
        <text class="copy-value">{{accountIdDisplay}}</text>
        <text class="copy-action icon-only">⧉</text>
      </view>

      <text class="field-label token-label">访问令牌</text>
      <view class="copy-field" bindtap="copyToken">
        <text class="copy-value token-value">{{maskedToken}}</text>
        <text class="copy-action icon-only">⧉</text>
      </view>

      <view class="import-row" bindtap="openImportDialog">
        <text class="import-text">输入访问令牌（切换到已有账号）</text>
      </view>

      <view class="card-divider lower-divider"></view>

      <view class="login-row">
        <view class="login-left">
          <text class="login-mark">●</text>
          <text class="login-text">{{loginStatusText}}</text>
        </view>
        <view class="login-right">
          <text wx:if="{{wechatAuthed}}" class="login-action" bindtap="signOut">退出登录</text>
          <text wx:else class="login-action {{wechatLoggingIn ? 'disabled' : ''}}" bindtap="wechatLogin">{{wechatLoggingIn ? '登录中...' : '微信登录'}}</text>
        </view>
      </view>
    </view>

    <view class="section-label">数据</view>
    <view class="stats-card">
      <view class="stat-row">
        <text class="stat-title">录音</text>
        <text class="stat-value">{{recordCount}} 条</text>
      </view>
      <view class="stat-row">
        <text class="stat-title">成文</text>
        <text class="stat-value">{{articleCount}} 篇</text>
      </view>
    </view>

    <view class="section-label">转移与登录</view>
    <view class="sync-card pairing-card {{pairing ? 'pairing-open' : ''}}">
      <view class="sync-row" bindtap="startDeviceLink">
        <text class="sync-title">设备配对登录</text>
        <text class="sync-action">发起</text>
      </view>
      <block wx:if="{{pairing}}">
        <input class="import-input pairing-input" value="{{pairingCode}}" bindinput="onPairingCodeInput" placeholder="输入验证码" />
        <button class="import-button" bindtap="verifyDeviceLink">验证</button>
        <button class="cancel-button" bindtap="cancelDeviceLink">取消配对</button>
      </block>
    </view>

    <view class="section-label">账户管理</view>
    <view class="delete-card" bindtap="deleteAccount">
      <text>删除账户</text>
    </view>
    <text class="section-note">永久删除云端与本机的全部数据（录音、文章、照片、设置、社区分享、登录绑定），不可恢复。</text>

    <!-- Token import modal dialog -->
    <view class="dialog-overlay" wx:if="{{showImportDialog}}" bindtap="cancelImport">
      <view class="dialog-card" catchtap="preventClose">
        <text class="dialog-title">输入访问令牌</text>
        <text class="dialog-desc">粘贴另一台设备「账户 → 访问令牌」复制的 anon_ 令牌，本机将切换到该账号（当前身份会被替换）。</text>
        <input class="dialog-input" value="{{importToken}}" bindinput="onImportInput" placeholder="anon_..." />
        <view class="dialog-actions">
          <view class="dialog-divider" />
          <view class="dialog-btn dialog-btn-cancel" bindtap="cancelImport">
            <text>取消</text>
          </view>
          <view class="dialog-btn-separator" />
          <view class="dialog-btn dialog-btn-confirm" bindtap="confirmImport">
            <text>切换</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
