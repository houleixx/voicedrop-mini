<view class="screen">
  <page-header title="{{title}}" />
  <view class="page-body agreement-body">
    <view class="agreement-card card">
      <text class="agreement-summary">{{summary}}</text>
      <view class="agreement-section" wx:for="{{sections}}" wx:key="title">
        <text class="section-title">{{item.title}}</text>
        <text class="section-paragraph" wx:for="{{item.paragraphs}}" wx:for-item="paragraph" wx:key="*this">{{paragraph}}</text>
      </view>
      <text class="agreement-meta">版本 {{version}} · 生效日期 {{effectiveDate}}</text>
    </view>
  </view>
</view>
