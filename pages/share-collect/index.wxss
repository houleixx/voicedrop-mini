.form,
.dataset,
.image-task,
.audio-task {
  margin-top: 24rpx;
  padding: 28rpx;
}

.audio-file {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6efe3;
}

.audio-name {
  display: block;
  overflow: hidden;
  color: #2a2521;
  font-size: 28rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.image-grid {
  display: grid;
  margin-top: 20rpx;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-cell {
  position: relative;
  overflow: hidden;
  border-radius: 12rpx;
  aspect-ratio: 1;
  background: #f1e7da;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-actions {
  display: grid;
  margin-top: 20rpx;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.field {
  width: 100%;
  margin-bottom: 18rpx;
}

.actions {
  display: grid;
  margin: 24rpx 0;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.danger {
  display: flex;
  min-height: 76rpx;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: #d8593b;
  background: #fae7e2;
  font-size: 28rpx;
  font-weight: 700;
}

.item {
  padding: 22rpx 0;
  border-top: 1rpx solid #f0e5d7;
}

.item-title,
.item-meta {
  display: block;
}

.item-title {
  color: #2a2521;
  font-size: 28rpx;
  font-weight: 800;
}

.item-meta {
  margin-top: 8rpx;
  color: #b8ae9e;
  font-size: 24rpx;
}
