<view class="screen">
  <page-header title="微信公众号" />
  <view class="page-body">
    <!-- Top info card -->
    <view wx:if="{{wechatConfigured}}" class="info-card info-card-connected">
      <text class="status-dot"></text>
      <view class="info-copy">
        <text class="connected-title">公众号已连接</text>
        <text class="connected-subtitle">凭据已保存</text>
      </view>
    </view>
    <view wx:else class="info-card">
      <text class="info-icon">◇</text>
      <text class="info-text">填入公众号 AppID / AppSecret 即可连接。</text>
    </view>

    <!-- Auto-push toggle -->
    <view class="toggle-card">
      <view class="toggle-left">
        <text class="toggle-title">自动推草稿</text>
        <text class="toggle-desc">挖出新文章后自动发到公众号草稿箱</text>
      </view>
      <switch checked="{{enabled}}" bindchange="onEnabled" color="#c7432f" />
    </view>

    <!-- Credentials section -->
    <text class="section-title">凭据</text>
    <view class="input-card">
      <input class="input-field" value="{{appid}}" data-key="appid" bindinput="onInput" placeholder="AppID (wx...)" />
    </view>
    <view class="input-card input-with-icon">
      <input class="input-field" value="{{secret}}" data-key="secret" bindinput="onInput" placeholder="AppSecret" password="{{secretHidden}}" />
      <text class="input-icon" bindtap="toggleSecret">◉</text>
    </view>
    <text class="input-note">凭据只保存在你的设备与服务器的加密配置里，不会出现在文章中。</text>
    <view class="help-row" bindtap="copyHelpLink">
      <text>去哪里找 AppID / AppSecret？</text>
      <text class="help-arrow">↗</text>
    </view>

    <!-- IP Whitelist section -->
    <view class="divider" />
    <text class="section-title">IP 白名单</text>
    <text class="section-desc">在公众号后台 → 开发 → 基本配置 → IP 白名单中加入以下地址，服务器才能正常调用接口推草稿。</text>
    <view class="ip-card">
      <text class="ip-address">66.42.45.128</text>
      <text class="copy-icon icon-only" bindtap="copyIp">⧉</text>
    </view>

    <!-- Save button -->
    <button class="save-button {{canSave ? 'save-button-active' : ''}}" disabled="{{!canSave || saving}}" loading="{{saving}}" bindtap="save">{{savedWechat ? '已保存' : '保存'}}</button>
    <button wx:if="{{wechatConfigured}}" class="disconnect-button" disabled="{{saving}}" bindtap="disconnectWechat">断开连接</button>
  </view>
</view>
