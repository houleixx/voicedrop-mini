<view class="screen settings-screen settings-page">
  <page-header title="设置" />
  <view class="page-body">

    <!-- 顶部卡片：账户、算力 -->
    <view class="card menu-card settings-primary-card">
      <!-- 账户 -->
      <view class="menu-item" data-url="/pages/account/index" bindtap="openPage">
        <view class="menu-icon icon-dark">
          <text class="menu-icon-text">✓</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">账户</text>
          <text class="menu-subtitle">无需登录 · ID 已随 iCloud 钥匙串备份</text>
        </view>
        <view class="menu-right">
          <text class="menu-value menu-id">{{shortAnonId}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <!-- 算力 -->
      <view class="menu-item no-bottom-border" data-url="/pages/usage/index" bindtap="openPage">
        <view class="menu-icon icon-amber">
          <text class="menu-icon-text">⚡</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">算力</text>
          <text class="menu-subtitle">约可成文 {{capacity}} 篇</text>
        </view>
        <view class="menu-right">
          <text class="menu-value">{{balance.suanli || 0}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 写作 -->
    <view class="section-header">写作</view>
    <view class="card menu-card">
      <!-- 名字 -->
      <view class="menu-item" bindtap="openNameEditor">
        <view class="menu-icon icon-beige">
          <view class="name-card-icon" aria-hidden="true">
            <view class="name-card-avatar"></view>
            <view class="name-card-lines">
              <view class="name-card-line name-card-line-short"></view>
              <view class="name-card-line"></view>
            </view>
          </view>
        </view>
        <view class="menu-content">
          <text class="menu-title">名字</text>
          <text class="menu-subtitle">署名和挖文章时对你的称呼</text>
        </view>
        <view class="menu-right">
          <text class="menu-status">{{profileName || ''}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <!-- 写作风格 -->
      <view class="menu-item" data-url="/pages/style-settings/index" bindtap="openPage">
        <view class="menu-icon icon-beige">
          <text class="menu-icon-text">✎</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">写作风格</text>
          <text class="menu-subtitle">成文时模仿这套语气</text>
        </view>
        <view class="menu-right">
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <!-- 提示词 -->
      <view class="menu-item no-bottom-border" data-url="/pages/instruction-settings/index" bindtap="openPage">
        <view class="menu-icon icon-beige"><text class="menu-icon-text">✦</text></view>
        <view class="menu-content">
          <text class="menu-title">提示词</text>
          <text class="menu-subtitle">自定义长按菜单里的每个动作</text>
        </view>
        <view class="menu-right"><text class="menu-arrow">›</text></view>
      </view>
    </view>

    <!-- 发布 -->
    <view class="section-header">发布</view>
    <view class="card menu-card">
      <!-- 微信公众号 -->
      <view class="menu-item" data-url="/pages/wechat-settings/index" bindtap="openPage">
        <view class="menu-icon icon-pink">
          <text class="menu-icon-text">➤</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">微信公众号</text>
          <text class="menu-subtitle">成文一键推送到草稿箱</text>
        </view>
        <view class="menu-right">
          <text class="menu-status {{wechatConfigured ? '' : 'menu-status-empty'}}">{{wechatConfigured ? '已配置' : '未配置'}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <!-- 自动分享到 VD 社区 -->
      <view class="menu-item no-bottom-border">
        <view class="menu-icon icon-green">
          <text class="menu-icon-text">☻</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">自动分享到 VD 社区</text>
          <text class="menu-subtitle">挖出新文章后自动发到社区</text>
        </view>
        <view class="menu-right">
          <switch checked="{{autoShareCommunity}}" bindchange="toggleAutoShare" color="#c7432f" />
        </view>
      </view>
    </view>

    <!-- 其他 -->
    <view class="section-header">其他</view>
    <view class="card menu-card">
      <!-- 关于 -->
      <view class="menu-item no-bottom-border" data-url="/pages/about/index" bindtap="openPage">
        <view class="menu-icon icon-beige">
          <text class="menu-icon-text">ℹ</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">关于</text>
          <text class="menu-subtitle"></text>
        </view>
        <view class="menu-right">
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="dialog-overlay" wx:if="{{nameEditorOpen}}" bindtap="closeNameEditor" style="padding-bottom: {{nameKeyboardHeight ? nameKeyboardHeight + 44 : 44}}px;">
      <view class="name-dialog" catchtap="preventNameEditorClose">
        <text class="dialog-title">名字</text>
        <input class="name-input" value="{{nameInput}}" bindinput="onNameInput" bindkeyboardheightchange="onNameKeyboardHeightChange" adjust-position="{{false}}" maxlength="20" placeholder="你的名字" focus="{{nameEditorOpen}}" />
        <text class="dialog-hint">这个名字会出现在文章署名，以及挖文章时对你的称呼。随时可改。</text>
        <view class="dialog-actions">
          <button class="dialog-button dialog-button-cancel" disabled="{{nameSaving}}" bindtap="closeNameEditor">取消</button>
          <button class="dialog-button dialog-button-confirm" loading="{{nameSaving}}" bindtap="saveName">完成</button>
        </view>
      </view>
    </view>

  </view>
</view>
