@import '../../styles/remixicon.wxss';

.screen {
  min-height: 100vh;
  padding: 0 28rpx 56rpx;
  background: #f9f2eb;
}

.nav-action {
  min-height: 52rpx;
  color: #c85a47;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 52rpx;
  text-align: left;
}

.nav-action-strong {
  text-align: right;
}

.dropdown-wrap {
  position: relative;
  z-index: 20;
}

.mode-picker {
  display: grid;
  grid-template-columns: auto 1fr auto;
  min-height: 80rpx;
  align-items: center;
  column-gap: 24rpx;
  padding: 0 22rpx;
  border: 3rpx solid #2f2d2a;
  border-radius: 16rpx;
  background: #fffdf9;
  box-shadow: 0 4rpx 0 rgba(31, 27, 22, 0.04);
}

.mode-chip {
  display: flex;
  min-width: 132rpx;
  min-height: 50rpx;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border-radius: 12rpx;
  color: #ffffff;
  background: #d9533f;
  font-size: 28rpx;
  font-weight: 800;
}

.chip-caret {
  font-size: 24rpx;
  line-height: 1;
}

.mode-summary {
  min-width: 0;
  overflow: hidden;
  color: #8f8980;
  font-size: 28rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mode-count {
  color: #b9b2a8;
  font-size: 28rpx;
  font-weight: 600;
}

.compare-panel {
  position: absolute;
  top: 96rpx;
  left: 0;
  right: 0;
  z-index: 30;
  overflow: hidden;
  border-radius: 18rpx;
  border: solid 1px rgb(118, 117, 117);
  background: rgba(255, 252, 247, 0.94);
  box-shadow: 0 20rpx 58rpx rgba(68, 54, 42, 0.16);
}

.compare-head {
  display: flex;
  min-height: 118rpx;
  align-items: center;
  background-color: #e6dbcf;
  justify-content: space-between;
  padding: 20rpx 26rpx;
  cursor: pointer;
}

.compare-head:active {
  background-color: #d9cfc4;
}

.compare-copy {
  min-width: 0;
}

.compare-title,
.compare-subtitle {
  display: block;
}

.compare-title {
  color: #24201d;
  font-size: 30rpx;
  font-weight: 800;
}

.compare-subtitle {
  margin-top: 8rpx;
  color: #bbb2a8;
  font-size: 24rpx;
  line-height: 1.35;
}

.compare-switch {
  transform: scale(.86);
  transform-origin: right center;
}

.version-list {
  padding: 14rpx;
}

.version-row {
  display: grid;
  grid-template-columns: 82rpx minmax(0, 1fr) 172rpx 52rpx;
  height: 94rpx;
  align-items: center;
  column-gap: 12rpx;
  margin-bottom: 14rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.78);
  overflow: hidden;
}

.version-row:last-child {
  margin-bottom: 0;
}

.version-row.selected {
  background: #fae4de;
}

.version-title {
  color: #24201d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 94rpx;
}

.version-row.selected .version-title,
.version-row.selected .version-preview {
  color: #d34d3d;
}

.version-preview {
  min-width: 0;
  max-height: 94rpx;
  overflow: hidden;
  color: #24201d;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 94rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.version-meta {
  max-height: 94rpx;
  overflow: hidden;
  color: #b6aea4;
  font-size: 24rpx;
  line-height: 94rpx;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.check-box {
  display: flex;
  width: 42rpx;
  height: 42rpx;
  align-items: center;
  justify-content: center;
  justify-self: end;
  border: 3rpx solid #ded8ce;
  border-radius: 10rpx;
  background: #fffefb;
}

.check-box.checked {
  border-color: #d9533f;
  background: #d9533f;
}

.check-mark {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.check-indicator {
  display: flex;
  width: 42rpx;
  height: 42rpx;
  align-items: center;
  justify-content: center;
  justify-self: end;
}

.check-indicator.selected .check-icon {
  color: #d9533f;
  font-size: 36rpx;
  font-weight: 900;
}

.version-empty {
  padding: 36rpx 24rpx;
  color: #aaa196;
  font-size: 26rpx;
  text-align: center;
}

.compare-foot {
  display: block;
  padding: 22rpx 24rpx 26rpx;
  color: #afa69c;
  background: rgba(249, 244, 238, 0.82);
  font-size: 24rpx;
  line-height: 1.55;
}

.panel-save-button {
  width: 100%;
  min-height: 80rpx;
  margin: 20rpx 24rpx 24rpx;
  border-radius: 12rpx;
  background: #d9533f;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 80rpx;
  text-align: center;
  border: none;
}

.panel-save-button::after {
  border: none;
}

.style-editor {
  margin-top: 28rpx;
  padding: 32rpx 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(65, 52, 41, 0.06);
}

.editor-label {
  display: block;
  margin-bottom: 16rpx;
  color: #29231f;
  font-size: 28rpx;
  font-weight: 800;
}

.textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 750rpx;
  padding: 28rpx 40rpx 28rpx 32rpx;
  border-color: #eaded2;
  border-radius: 18rpx;
  background: #fffdf9;
  line-height: 1.55;
}

.save-button {
  margin-top: 20rpx;
}
