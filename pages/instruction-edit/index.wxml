<view class="screen">
  <page-header title="{{pageTitle}}" />
  <view class="edit-page" wx:if="{{!loading && item}}">
    <text class="error" wx:if="{{error}}">{{error}}</text>
    <text class="field-label">名称</text><input class="field" maxlength="40" value="{{nameDraft}}" bindinput="onNameInput" />
    <block wx:if="{{item.type === 'action'}}">
      <text class="field-label section-gap">提示词</text><textarea class="field prompt-field" value="{{instructionDraft}}" bindinput="onInstructionInput" />
      <view class="hide-card"><text>应用于文字</text><switch checked="{{textDraft}}" bindchange="onTextChange" color="#c7432f" /></view>
      <view class="hide-card"><text>应用于图片</text><switch checked="{{imageDraft}}" bindchange="onImageChange" color="#c7432f" /></view>
      <view class="share-card"><view class="setting-copy"><text>分享这条提示词</text><text class="hint">开启后可用分享码或链接导入</text></view><switch checked="{{sharing}}" disabled="{{shareToggling}}" bindchange="toggleSharing" color="#c7432f" /></view>
      <text class="share-error" wx:if="{{shareError}}">{{shareError}}</text>
      <view class="share-details" wx:if="{{shareCode}}"><view class="share-value-row"><text class="share-value">{{shareCode}}</text><button bindtap="copyShareCode">复制数字</button></view><view class="share-value-row"><text class="share-link">voicedrop.cn/{{shareCode}}</text><button bindtap="copyShareLink">复制链接</button></view><button class="wechat-share" open-type="share">微信分享</button><text class="share-warning" wx:if="{{dirty}}">分享的始终是已保存的版本，请先保存当前修改。</text></view>
    </block>
    <text class="default-note">系统提示词编辑时会保存为独立副本，服务端后续更新不会覆盖你的版本。</text>
    <button class="save-button" disabled="{{!dirty || saving}}" loading="{{saving}}" bindtap="save">保存</button>
  </view>
  <view class="loading" wx:else>{{error || '正在加载...'}}</view>
</view>
