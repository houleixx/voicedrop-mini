<view class="screen settings-screen">
  <page-header title="{{pageTitle}}" />
  <view class="edit-page settings-content" wx:if="{{!loading && item}}">
    <text class="error" wx:if="{{error}}">{{error}}</text>
    <text class="field-label">菜单里的名字</text><input class="field" maxlength="40" value="{{nameDraft}}" bindinput="onNameInput" />
    <block wx:if="{{item.type === 'action'}}">
      <text class="field-label section-gap">提示词</text><textarea class="field prompt-field" value="{{instructionDraft}}" bindinput="onInstructionInput" />
      <view class="applies-head"><text class="field-label">适用于</text><text>决定在哪种长按里出现</text></view>
      <view class="apply-options"><view class="apply-option {{textDraft ? 'selected' : ''}}" bindtap="toggleText"><text class="ri-edit-2-line"></text><text>文字</text><text class="apply-check">{{textDraft ? '✓' : ''}}</text></view><view class="apply-option image-option {{imageDraft ? 'selected' : ''}}" bindtap="toggleImage"><text class="ri-image-line"></text><text>图片</text><text class="apply-check">{{imageDraft ? '✓' : ''}}</text></view></view>
      <view class="share-card">
        <view class="share-head">
          <view class="setting-copy">
            <text>分享这条提示词</text>
            <text class="hint">{{sharing ? '分享中，关闭后分享码立即失效' : '开启后，任何人对 VoiceDrop 说出分享码，或打开链接，就能看到并一次性使用这条提示词'}}</text>
          </view>
          <switch checked="{{sharing}}" disabled="{{shareToggling}}" bindchange="toggleSharing" color="#c7432f" />
        </view>
        <text class="share-error" wx:if="{{shareError}}">{{shareError}}</text>
        <view class="share-details" wx:if="{{sharing && shareCode}}">
          <text class="share-value">{{shareCode}}</text>
          <text class="share-link">voicedrop.cn/{{shareCode}}</text>
          <view class="share-actions">
            <button class="share-action" bindtap="copyShareCode"><text class="ri-file-copy-line"></text><text>复制数字</text></button>
            <button class="share-action" bindtap="copyShareLink"><text class="ri-link"></text><text>复制链接</text></button>
            <button class="share-action" open-type="share"><text class="ri-share-box-line"></text><text>分享…</text></button>
          </view>
          <text class="share-warning" wx:if="{{dirty}}">分享的始终是已保存的版本</text>
        </view>
      </view>
    </block>
    <button class="bottom-save {{dirty && !saving ? '' : 'disabled'}}" disabled="{{!dirty || saving}}" loading="{{saving}}" bindtap="save">{{saving ? '保存中' : '保存'}}</button>
  </view>
  <view class="loading" wx:else>{{error || '正在加载...'}}</view>
</view>
